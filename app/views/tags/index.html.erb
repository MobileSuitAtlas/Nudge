<div class="container my-4">
    <h1 class="mb-4 text-center">Manage Tags 🏷️</h1>

    <div class="d-flex gap-2 mb-4 justify-content-center">
        <%= link_to "← Back to Habits", habits_path, class: "btn btn-outline-secondary" %>
    </div>

    <%# Create new tag form %>
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Create New Tag</h5>
            <%= form_with model: @tag, url: tags_path, local: true, class: "d-flex gap-2 align-items-center" do |f| %>
                <%= f.text_field :name, placeholder: "Tag name", class: "form-control", required: true %>
                <%= f.color_field :color, class: "form-control form-control-color", title: "Choose color" %>
                <%= f.submit "Create Tag", class: "btn btn-primary" %>
            <% end %>
        </div>
    </div>

    <%# Tags list %>
    <div class="row gy-3">
        <% @tags.each do |tag| %>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="badge fs-6" style="background-color: <%= tag.color %>;"><%= tag.name %></span>
                            <small class="text-muted"><%= tag.habits.count %> habits</small>
                        </div>
                        
                        <div class="d-flex gap-2 mt-auto">
                            <%= form_with model: tag, url: tag_path(tag), local: true, class: "d-flex gap-2 flex-fill", method: :patch do |f| %>
                                <%= f.text_field :name, class: "form-control form-control-sm", placeholder: "Name" %>
                                <%= f.color_field :color, class: "form-control form-control-color form-control-sm", title: "Choose color" %>
                                <%= f.submit "Update", class: "btn btn-outline-primary btn-sm" %>
                            <% end %>
                            
                            <%= button_to "🗑️", tag_path(tag), method: :delete, class: "btn btn-outline-danger btn-sm", data: { confirm: "Delete this tag? It will be removed from all habits." } %>
                        </div>
                    </div>
                </div>
            </div>
        <% end %>
    </div>

    <% if @tags.empty? %>
        <div class="text-center text-muted mt-4">
            <p>No tags yet. Create one above!</p>
        </div>
    <% end %>
</div>
