<div class="container my-4">
    <h1 class="mb-4 text-center"> Today's Easy Habits list :) </h1>

    <div class="mb-4 pb-3 border-bottom">
        <!-- might need to change the line below -->
        <div class="d-flex justify-content-between align-items-center">
            <div class="text-center">
                <%= link_to "Current list of Habits!", habits_path, class: "btn btn-outline-primary" %>
                <%= link_to "Let's start a New Habit :)", new_habit_path, class: "btn btn-primary" %>
            </div>

            <%=button_to "In case you need a little Nudge :D", nudge_habit_path(@habits.sample), method: :post, class: "btn btn-primary w-100" %>               
        </div>
    </div>

    <% if @focus_habit %>
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Today's Focus Habit :)</h5>

                <p class="fs-5 mb-1">
                    <%= @focus_habit.icon %> <%= @focus_habit.name %>
                </p>

                <% if @focus_habit.prompt.present? %>
                    <p class="text-muted mb-2"><%= @focus_habit.prompt %></p>
                <% end %>

                <p class="text-muted small">today :D</p>

                <%= button_to "Reset Focus Habit", reset_focus_habits_path, method: :post, class: "btn btn-outline-secondary btn-sm" %>                  
            </div>
        </div>
    <% end %>

    <h2 style="mb-3">Your Habits</h2>

    <div class="row gy-3">
        <% @habits.each do |habit| %>
            <% checked_in_today = habit.check_ins.exists?(date: Date.today) %>
            
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= habit.icon %> <%= habit.name %>
                        </h5>

                        <% if habit.prompt.present? %>
                            <p class="text-muted"><% habit.prompt %></p>
                        <% end %>

                        <div class="d-flex flex-column gap-2">

                            <% if checked_in_today %>
                                <span class="text-success fw-bold"> Done already? Awesome job today! :D </span>                               
                            <% else %>
                                <%= button_to "Mark Done for Today", check_in_habit_path(habit), method: :post, class: "btn btn-success" %>
                            <% end %>
                            
                            <%= button_to "Set as Focus", set_focus_habit_path(habit), method: :post, class: "btn btn-outline-primary" %>

                        </div>
                    
                    </div>
                </div>
            </div>
        <% end %>
    </div>
                                
</div>